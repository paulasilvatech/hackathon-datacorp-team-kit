      "small": {
        "$value": {
          "fontSize": "24px",
          "lineHeight": "1.4",
          "letterSpacing": "0",
          "fontWeight": 400,
          "fontFamily": "{typography.family.sans}"
        },
        "$type": "typography",
        "$description": "Texto pequeno, captions, legendas"
      },
      "eyebrow": {
        "$value": {
          "fontSize": "24px",
          "lineHeight": "1.2",
