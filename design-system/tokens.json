      "semibold": {
        "$value": 600,
        "$type": "fontWeight",
        "$description": "Peso semi bold, ênfase moderada"
      },
      "bold": {
        "$value": 700,
        "$type": "fontWeight",
        "$description": "Peso bold, ênfase forte"
      }
    },
    "scale": {
      "title": {
        "$value": {
          "fontSize": "72px",
          "lineHeight": "1.02",
          "letterSpacing": "-0.02em",
          "fontWeight": 500,
          "fontFamily": "{typography.family.sans}"
        },
        "$type": "typography",
        "$description": "Título principal de slide"
      },
      "subtitle": {
        "$value": {
          "fontSize": "44px",
          "lineHeight": "1.15",
          "letterSpacing": "-0.015em",
          "fontWeight": 400,
          "fontFamily": "{typography.family.sans}"
        },
        "$type": "typography",
        "$description": "Subtítulo de slide, texto destacado"
