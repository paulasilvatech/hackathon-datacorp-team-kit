        "$type": "typography",
        "$description": "Eyebrow, marcação de seção ou categoria, sempre uppercase"
      },
      "big-num": {
        "$value": {
          "fontSize": "240px",
          "lineHeight": "0.9",
          "letterSpacing": "-0.04em",
          "fontWeight": 300,
          "fontFamily": "{typography.family.sans}"
        },
        "$type": "typography",
        "$description": "Big number stat, destaque numérico grande"
      },
      "section-title": {
        "$value": {
          "fontSize": "160px",
          "lineHeight": "0.95",
          "letterSpacing": "-0.035em",
          "fontWeight": 500,
          "fontFamily": "{typography.family.sans}"
        },
        "$type": "typography",
        "$description": "Título de divisor de seção em slide dark"
