  "typography": {
    "family": {
      "sans": {
        "$value": "Inter, -apple-system, Helvetica, sans-serif",
        "$type": "fontFamily",
        "$description": "Família principal, usada em títulos, corpo, UI"
      },
      "mono": {
        "$value": "JetBrains Mono, monospace",
        "$type": "fontFamily",
        "$description": "Família monoespaçada, usada em eyebrows, números, código, metadados"
      }
    },
    "weight": {
      "light": {
        "$value": 300,
        "$type": "fontWeight",
        "$description": "Peso leve, usado em big numbers"
      },
      "regular": {
        "$value": 400,
        "$type": "fontWeight",
        "$description": "Peso regular, corpo de texto padrão"
      },
      "medium": {
        "$value": 500,
        "$type": "fontWeight",
        "$description": "Peso médio, títulos e eyebrows"
